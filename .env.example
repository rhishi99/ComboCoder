# FreeAgentDev Environment Configuration
# Copy this file to .env and fill in your API keys
# At least one provider is required

# Groq - Fastest inference, generous free tier
# Get key at: https://console.groq.com/
GROQ_API_KEY=

# NVIDIA NIM - Wide model variety (GLM, Kimi, MiniMax, DeepSeek)
# Get key at: https://build.nvidia.com/
NVIDIA_API_KEY=

# OpenRouter - Aggregates many providers, some free models
# Get key at: https://openrouter.ai/
OPENROUTER_API_KEY=

# Google AI Studio - Gemini models, very generous free tier
# Get key at: https://aistudio.google.com/
GOOGLE_API_KEY=

# Cerebras - Ultra-fast inference
# Get key at: https://cerebras.ai/
CEREBRAS_API_KEY=

# Together AI - Many open models
# Get key at: https://api.together.xyz/
TOGETHER_API_KEY=

# DeepInfra - Cost-effective
# Get key at: https://deepinfra.com/
DEEPINFRA_API_KEY=

# Fireworks AI - Fast inference, free credits
# Get key at: https://fireworks.ai/
FIREWORKS_API_KEY=

# OpenCode - Community-driven
# Get key at: https://opencode.ai/
OPENCODE_API_KEY=
